# Server Environment Variables Template
# Copy this file to '.env' and configure the values

# Port for the server to listen on
PORT=5000

# MongoDB Connection String (Local or MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/inventory_db

# JSON Web Token Secrets (use secure, long strings in production)
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_key_here
JWT_EXPIRES_IN=7d

# SMTP Email Configuration for Password Resets/Notifications
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password

# Frontend application URL (for CORS and reset links)
FRONTEND_URL=http://localhost:5173

# Node Environment (development or production)
NODE_ENV=development

# Relative or absolute path for file uploads
UPLOAD_PATH=./uploads
